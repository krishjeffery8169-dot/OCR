PORT=3001
HOST=0.0.0.0

# 服务器上的 PowerShell 截题脚本路径。Windows Server 推荐使用绝对路径。
CROP_SCRIPT_PATH=C:\tools\model-crop\scripts\docx_wordml_crop_generic.ps1

# Windows PowerShell 5 默认 powershell.exe；PowerShell 7 可改为 pwsh.exe。
POWERSHELL_EXE=powershell.exe

# 任务临时目录和结果目录。建议放到容量较大的磁盘。
MODEL_CROP_RUNTIME_ROOT=D:\model-crop-runtime
MODEL_CROP_UPLOAD_LIMIT_MB=120

# 可选：服务器统一配置模型 Key，页面里就不用每次填写。
OPENROUTER_API_KEY=
